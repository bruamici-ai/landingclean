<section class="gallery-entry">
  <div class="gallery-entry__inner">
    <div>
      <p class="eyebrow">Recorrido fotográfico</p>
      <h2>Explorá la casa por ambientes</h2>
      <p class="lead">Descubrí cada espacio en un recorrido visual pensado para que puedas imaginar tu estadía desde el primer vistazo.</p>
    </div>

    <button class="open-gallery-btn" type="button" id="open-room-gallery">
      Ver galería completa
    </button>
  </div>
</section>

<div class="gallery-overlay" id="room-gallery-overlay" aria-hidden="true">
  <div class="gallery-overlay__backdrop" data-close-gallery></div>

  <div class="gallery-overlay__panel" role="dialog" aria-modal="true" aria-labelledby="room-gallery-title">
    <div class="gallery-overlay__topbar">
      <div>
        <p class="eyebrow">Galería</p>
        <h3 id="room-gallery-title">Recorrido por ambientes</h3>
      </div>

      <button class="close-gallery-btn" type="button" data-close-gallery aria-label="Cerrar galería">
        ✕
      </button>
    </div>

    <nav class="gallery-overlay__nav">
      {rooms.map((room) => (
        <a href={`#${room.id}`}>{room.title}</a>
      ))}
    </nav>

    <div class="gallery-overlay__content">
      {rooms.map((room) => (
        <section class="room-block" id={room.id}>
          <div class="room-block__head">
            <p class="eyebrow">{room.title}</p>
            <h4>{room.subtitle}</h4>
          </div>

          <div class="room-block__photos">
            {room.images.map((img, i) => (
              <figure class={`room-photo ${i === 0 ? "room-photo--hero" : ""}`}>
                <img
                  src={img}
                  alt={`${room.title} ${i + 1}`}
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</div>

<script>
  const openBtn = document.getElementById("open-room-gallery");
  const overlay = document.getElementById("room-gallery-overlay");
  const closeBtns = document.querySelectorAll("[data-close-gallery]");

  const openGallery = () => {
    overlay?.setAttribute("aria-hidden", "false");
    document.documentElement.style.overflow = "hidden";
    document.body.style.overflow = "hidden";
  };

  const closeGallery = () => {
    overlay?.setAttribute("aria-hidden", "true");
    document.documentElement.style.overflow = "";
    document.body.style.overflow = "";
  };

  openBtn?.addEventListener("click", openGallery);
  closeBtns.forEach((btn) => btn.addEventListener("click", closeGallery));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && overlay?.getAttribute("aria-hidden") === "false") {
      closeGallery();
    }
  });
</script>

<style>
  .gallery-entry {
    padding: 1rem 1rem 0;
  }

  .gallery-entry__inner {
    display: grid;
    gap: 1rem;
    padding: 1.1rem;
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.04));
    border: 1px solid rgba(255,255,255,.12);
  }

  .eyebrow {
    margin: 0 0 .25rem;
    font-size: .72rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    opacity: .7;
  }

  .gallery-entry h2,
  .gallery-overlay h3,
  .room-block h4 {
    margin: 0;
    line-height: 1.05;
  }

  .lead {
    margin: .5rem 0 0;
    font-size: .96rem;
    line-height: 1.45;
    opacity: .88;
  }

  .open-gallery-btn,
  .close-gallery-btn {
    appearance: none;
    border: 0;
    cursor: pointer;
  }

  .open-gallery-btn {
    width: 100%;
    border-radius: 999px;
    padding: .95rem 1rem;
    font-weight: 700;
    font-size: .96rem;
    background: #fff;
    color: #111;
  }

  .gallery-overlay {
    position: fixed;
    inset: 0;
    z-index: 120;
    pointer-events: none;
  }

  .gallery-overlay[aria-hidden="false"] {
    pointer-events: auto;
  }

  .gallery-overlay__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, .62);
    opacity: 0;
    transition: opacity .25s ease;
  }

  .gallery-overlay__panel {
    position: absolute;
    inset: auto 0 0 0;
    height: 92dvh;
    background: #f5f5f3;
    color: #171717;
    border-radius: 24px 24px 0 0;
    transform: translateY(100%);
    transition: transform .28s ease;
    display: grid;
    grid-template-rows: auto auto 1fr;
    overflow: hidden;
    box-shadow: 0 -20px 60px rgba(0,0,0,.28);
  }

  .gallery-overlay[aria-hidden="false"] .gallery-overlay__backdrop {
    opacity: 1;
  }

  .gallery-overlay[aria-hidden="false"] .gallery-overlay__panel {
    transform: translateY(0);
  }

  .gallery-overlay__topbar {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 1rem;
    padding: 1rem 1rem .75rem;
    background: #f5f5f3;
    border-bottom: 1px solid rgba(0,0,0,.08);
  }

  .close-gallery-btn {
    width: 42px;
    height: 42px;
    border-radius: 999px;
    background: #111;
    color: #fff;
    font-size: 1rem;
    flex: 0 0 auto;
  }

  .gallery-overlay__nav {
    display: flex;
    gap: .55rem;
    overflow-x: auto;
    padding: .75rem 1rem;
    background: #f5f5f3;
    border-bottom: 1px solid rgba(0,0,0,.08);
    scrollbar-width: none;
  }

  .gallery-overlay__nav::-webkit-scrollbar {
    display: none;
  }

  .gallery-overlay__nav a {
    flex: 0 0 auto;
    text-decoration: none;
    color: #171717;
    background: #fff;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 999px;
    padding: .65rem .9rem;
    font-size: .9rem;
    white-space: nowrap;
  }

  .gallery-overlay__content {
    overflow-y: auto;
    padding: 1rem;
    -webkit-overflow-scrolling: touch;
  }

  .room-block {
    margin-bottom: 1.4rem;
    scroll-margin-top: 1rem;
  }

  .room-block__head {
    margin-bottom: .75rem;
  }

  .room-block__photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .55rem;
  }

  .room-photo {
    margin: 0;
    overflow: hidden;
    border-radius: 18px;
    background: #ddd;
    min-height: 120px;
  }

  .room-photo--hero {
    grid-column: 1 / -1;
    min-height: 220px;
  }

  .room-photo img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .gallery-entry {
      padding: 1.25rem 0 0;
    }

    .gallery-entry__inner {
      padding: 1.25rem;
      grid-template-columns: 1.4fr auto;
      align-items: center;
    }

    .open-gallery-btn {
      width: auto;
      min-width: 220px;
    }

    .gallery-overlay__panel {
      inset: 2rem;
      height: auto;
      border-radius: 28px;
    }

    .room-block__photos {
      grid-template-columns: repeat(3, 1fr);
    }

    .room-photo--hero {
      grid-column: span 2;
      grid-row: span 2;
      min-height: 360px;
    }
  }
</style>
