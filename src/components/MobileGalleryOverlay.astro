---

<div class="gallery-overlay" id="galleryOverlay" aria-hidden="true">
  <div class="gallery-panel">
    <div class="gallery-header">
      <div>
        <div class="gallery-kicker">Galería</div>
        <h2>Recorrido por ambientes</h2>
      </div>
      <button class="gallery-close" id="galleryClose" aria-label="Cerrar">×</button>
    </div>

    <div class="gallery-tabs">
      {sections.map((section) => (
        <button class="gallery-tab" data-target={section.id}>{section.tab}</button>
      ))}
    </div>

    <div class="gallery-body">
      {sections.map((section, idx) => (
        <section
          class:list={["gallery-section", idx === 0 && "is-active"]}
          id={section.id}
        >
          <div class="section-copy">
            <div class="section-kicker">{section.tab}</div>
            <h3>{section.title}</h3>
            <p>{section.subtitle}</p>
          </div>

          <div class="section-grid">
            {section.images.map((img, i) => (
              <a
                href={img}
                target="_blank"
                rel="noreferrer"
                class:list={["section-item", i === 0 && "section-item--hero"]}
              >
                <img src={img} alt={`${section.title} ${i + 1}`} loading="lazy" />
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</div>

<button class="gallery-floating-trigger" id="galleryOpen">
  Mostrar galería completa
</button>

<script>
  const overlay = document.getElementById('galleryOverlay');
  const openBtn = document.getElementById('galleryOpen');
  const closeBtn = document.getElementById('galleryClose');
  const tabs = Array.from(document.querySelectorAll('.gallery-tab'));
  const sectionsEls = Array.from(document.querySelectorAll('.gallery-section'));

  function openGallery() {
    if (!overlay) return;
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeGallery() {
    if (!overlay) return;
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function activateSection(id) {
    sectionsEls.forEach((el) => {
      el.classList.toggle('is-active', el.id === id);
    });
    tabs.forEach((tab) => {
      tab.classList.toggle('is-active', tab.dataset.target === id);
    });
  }

  if (openBtn) openBtn.addEventListener('click', openGallery);
  if (closeBtn) closeBtn.addEventListener('click', closeGallery);

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => activateSection(tab.dataset.target));
  });

  if (overlay) {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeGallery();
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('is-open')) {
      closeGallery();
    }
  });

  if (tabs.length) tabs[0].classList.add('is-active');
</script>

<style>
  .gallery-floating-trigger{
    display:none;
  }

  .gallery-overlay{
    position:fixed;
    inset:0;
    background:rgba(18,18,18,.48);
    backdrop-filter:blur(10px);
    z-index:120;
    opacity:0;
    pointer-events:none;
    transition:.22s ease;
  }

  .gallery-overlay.is-open{
    opacity:1;
    pointer-events:auto;
  }

  .gallery-panel{
    position:absolute;
    inset:24px;
    background:#f7f4ee;
    border-radius:28px;
    overflow:hidden;
    box-shadow:0 24px 80px rgba(0,0,0,.24);
    display:flex;
    flex-direction:column;
  }

  .gallery-header{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:16px;
    padding:22px 24px 16px;
    border-bottom:1px solid rgba(30,35,29,.08);
    background:#f7f4ee;
  }

  .gallery-kicker,
  .section-kicker{
    text-transform:uppercase;
    letter-spacing:.08em;
    font-size:12px;
    color:#7a7a72;
    font-weight:700;
  }

  .gallery-header h2{
    margin:6px 0 0;
    font-size:34px;
    line-height:1;
  }

  .gallery-close{
    width:44px;
    height:44px;
    border:none;
    border-radius:999px;
    background:#111;
    color:#fff;
    font-size:28px;
    cursor:pointer;
  }

  .gallery-tabs{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    padding:14px 24px;
    border-bottom:1px solid rgba(30,35,29,.08);
    background:#f7f4ee;
  }

  .gallery-tab{
    border:1px solid rgba(30,35,29,.08);
    background:#fff;
    color:#5f665b;
    padding:10px 14px;
    border-radius:999px;
    font-weight:700;
    cursor:pointer;
  }

  .gallery-tab.is-active{
    background:#6d7552;
    color:#fff;
    border-color:#6d7552;
  }

  .gallery-body{
    flex:1;
    overflow:auto;
    padding:24px;
  }

  .gallery-section{
    display:none;
  }

  .gallery-section.is-active{
    display:block;
  }

  .section-copy{
    margin-bottom:18px;
  }

  .section-copy h3{
    margin:8px 0 8px;
    font-size:34px;
    line-height:1;
  }

  .section-copy p{
    margin:0;
    color:#636b61;
    line-height:1.7;
    max-width:62ch;
  }

  .section-grid{
    display:grid;
    grid-template-columns:1.35fr .65fr;
    gap:14px;
  }

  .section-item{
    display:block;
    border-radius:22px;
    overflow:hidden;
    background:#ddd;
    min-height:260px;
  }

  .section-item--hero{
    grid-row:span 2;
    min-height:540px;
  }

  .section-item img{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
  }

  @media (max-width: 900px){
    .gallery-panel{
      inset:12px;
      border-radius:22px;
    }

    .gallery-header h2,
    .section-copy h3{
      font-size:28px;
    }

    .section-grid{
      grid-template-columns:1fr;
    }

    .section-item,
    .section-item--hero{
      min-height:220px;
      grid-row:auto;
    }
  }
</style>
