  "normas_normalizadas": [
    {
      "titulo": "Ingreso y registro de huéspedes",
      "reglas": [
        "Solo pueden ingresar huéspedes registrados en la reserva.",
        "Las visitas deben ser avisadas con anticipación y requieren nombre, apellido y foto del DNI o pasaporte.",
