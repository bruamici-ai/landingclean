    images: [
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883739/IMG_4598_cwncxw.jpg',
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883738/IMG_4600_upipwh.jpg',
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883737/IMG_4603_zj8dqb.jpg',
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883739/IMG_4601_qkexta.jpg',
    ]
  },
  {
    label: 'Baño en suite',
    images: [
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883740/IMG_4604_xagxvy.jpg',
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883739/IMG_4611_oslz2z.jpg',
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883739/IMG_4609_pgghx3.jpg',
    ]
  },
  {
    label: 'Habitación 2',
    images: [
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883739/IMG_4613_u1gdxu.jpg',
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883739/IMG_4617_zrjksh.jpg',
    ]
  },
  {
    label: 'Habitación 3',
    images: [
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883740/IMG_4621_puxhxl.jpg',
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883740/IMG_4623_euazyn.jpg',
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883740/IMG_4625_mkwxus.jpg',
    ]
  },
  {
    label: 'Baño principal',
    images: [
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883740/IMG_4619_m68loq.jpg',
      'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883740/IMG_4620_t0v9ya.jpg',
    ]
  },
