---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryModal from "../components/GalleryModal.astro";

const phone = "5492616545175";
const wa = `https://wa.me/${phone}?text=${encodeURIComponent("Hola Heliana, quiero consultar por Casa Avellaneda en Mendoza.")}`;

const heroImage = "https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775883741/IMG_4631_rmcvwh.jpg";

// Hero side cards
const heroSide = {
