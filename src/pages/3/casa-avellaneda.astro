const highlights = [
  {
    icon: '📍',
    title: '5ta Sección, zona muy buscada',
    text: 'En Nicolás Avellaneda, entre Belgrano y Tiburcio Benegas. Cerca de Aristides, del Parque San Martín y de servicios para moverse con comodidad.'
  },
  {
    icon: '💦',
    title: 'Patio con piscina y parrilla',
    text: 'Un exterior agradable para bajar el ritmo, refrescarse y disfrutar la casa en grupo. Parrilla para comidas largas y sobremesas con aire mendocino.'
  },
  {
    icon: '🚗',
    title: 'Cochera doble incluida',
    text: 'Dos plazas dentro de la propiedad para que llegues sin preocuparte por el estacionamiento, especialmente útil para grupos que viajan en auto.'
  },
  {
    icon: '🏠',
    title: 'Amplitud real para grupos',
    text: 'Con capacidad para hasta 10 huéspedes, 3 habitaciones, 8 camas y 3.5 baños. La distribución permite convivir con comodidad sin pisarse.'
  }
