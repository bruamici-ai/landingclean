---
import reviewsRaw from '../../data/la-casa-frente-al-parque-reviews.json';

type Review = {
  review_id: string;
  platform: 'airbnb' | 'booking' | string;
  guest_name: string | null;
  listing_name: string | null;
  stay_start_date: string | null;
  stay_end_date: string | null;
  review_published_at: string | null;
  nights: number | null;
  overall_score: number | null;
  currency_or_scale: string | null;
  title: string | null;
  comment_public: string | null;
  comment_positive: string | null;
  comment_negative: string | null;
  comment_private: string | null;
  display_language_note: string | null;
  is_platform_translated: boolean;
  source_order: number | null;
  source_file: string | null;
  is_duplicate: boolean;
  duplicate_of_review_id: string | null;
  raw_stay_text: string | null;
  tags: string[];
};

const reviews = reviewsRaw as Review[];

const uniqueReviews = reviews.filter((r) => !r.is_duplicate);
const totalReviews = uniqueReviews.length;

const avgScore = (items: Review[]) => {
  const scores = items.map((r) => Number(r.overall_score)).filter((n) => !Number.isNaN(n));
  if (!scores.length) return null;
  return (scores.reduce((a, b) => a + b, 0) / scores.length).toFixed(1);
};

const airbnb = uniqueReviews.filter((r) => r.platform === 'airbnb');
const booking = uniqueReviews.filter((r) => r.platform === 'booking');

const tagLabels: Record<string, string> = {
  host_service: 'Atención del anfitrión',
  location: 'Ubicación',
  cleanliness: 'Limpieza',
  security: 'Seguridad',
  spaciousness: 'Amplitud',
  comfort_beds: 'Confort / camas',
  group_friendly: 'Ideal grupos',
  maintenance: 'Mantenimiento',
  pool_outdoor: 'Pileta / exterior',
  value: 'Relación precio-calidad',
};

const tagCounts = uniqueReviews.reduce((acc, review) => {
  review.tags.forEach((tag) => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

const sortedReviews = [...reviews].sort((a, b) => {
  const parseSafe = (value: string | null) => {
    if (!value) return new Date('1900-01-01T00:00:00').getTime();
    const normalized = String(value).trim();
    const d = new Date(normalized.includes('T') ? normalized : `${normalized}T00:00:00`);
    return Number.isNaN(d.getTime()) ? new Date('1900-01-01T00:00:00').getTime() : d.getTime();
  };

  const da = parseSafe(a.review_published_at || a.stay_start_date);
  const db = parseSafe(b.review_published_at || b.stay_start_date);
  return db - da;
});

const formatDate = (date: string | null) => {
  if (!date) return 'Sin fecha';

  const normalized = String(date).trim();
  const d = new Date(normalized.includes('T') ? normalized : `${normalized}T00:00:00`);

  if (Number.isNaN(d.getTime())) return normalized;

  return new Intl.DateTimeFormat('es-AR', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  }).format(d);
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Interno | Reseñas – La Casa Frente al Parque</title>
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Uso interno · Landing Casas</p>
          <h1>Reseñas · La Casa Frente al Parque</h1>
          <p class="lead">
            Vista interna para leer, filtrar y revisar la base normalizada de reseñas de Airbnb y
            Booking. Pensada para análisis operativo, copy comercial y curaduría de testimonios.
          </p>
        </div>

        <div class="hero-stats">
          <article class="stat">
            <span>Total útiles</span>
            <strong>{totalReviews}</strong>
            <small>sin duplicados</small>
          </article>
          <article class="stat">
            <span>Airbnb</span>
            <strong>{airbnb.length}</strong>
            <small>promedio {avgScore(airbnb) ?? '-'}</small>
          </article>
          <article class="stat">
            <span>Booking</span>
            <strong>{booking.length}</strong>
            <small>promedio {avgScore(booking) ?? '-'}</small>
          </article>
          <article class="stat">
            <span>Promedio general</span>
            <strong>{avgScore(uniqueReviews) ?? '-'}</strong>
            <small>escala según plataforma</small>
          </article>
        </div>
      </section>

      <section class="summary">
        <div class="panel">
          <h2>Temas más repetidos</h2>
          <div class="chips">
            {topTags.map(([tag, count]) => (
              <span class="chip">{tagLabels[tag] ?? tag} · {count}</span>
            ))}
          </div>
        </div>
        <div class="panel">
          <h2>Cómo usar esta vista</h2>
          <ul>
            <li>Filtrá por plataforma, score, tema o texto.</li>
            <li>Ocultá duplicados para una lectura limpia.</li>
            <li>Copiá testimonios para landing, anuncios o respuestas.</li>
          </ul>
        </div>
      </section>

      <section class="toolbar">
        <div class="field wide">
          <label for="search">Buscar en nombre o comentario</label>
          <input id="search" type="search" placeholder="Ej: parque, limpia, familia, anfitrión..." />
        </div>

        <div class="field">
          <label for="platform">Plataforma</label>
          <select id="platform">
            <option value="all">Todas</option>
            <option value="airbnb">Airbnb</option>
            <option value="booking">Booking</option>
          </select>
        </div>

        <div class="field">
          <label for="tag">Tema</label>
          <select id="tag">
            <option value="all">Todos</option>
            {Object.entries(tagLabels).map(([value, label]) => (
              <option value={value}>{label}</option>
            ))}
          </select>
        </div>

        <div class="field">
          <label for="score">Score mínimo</label>
          <select id="score">
            <option value="0">Todos</option>
            <option value="4">4+</option>
            <option value="4.5">4.5+</option>
            <option value="5">5 / 10</option>
            <option value="9">9 / 10</option>
          </select>
        </div>

        <label class="check">
          <input id="hideDuplicates" type="checkbox" checked />
          Ocultar duplicados
        </label>
      </section>

      <section class="results-head">
        <div>
          <h2>Base completa</h2>
          <p id="resultsCount">{reviews.length} reseñas cargadas</p>
        </div>
      </section>

      <section class="reviews" id="reviewsList">
        {sortedReviews.map((review) => {
          const mainText = review.comment_public || review.comment_positive || review.title || '';
          const negativeText = review.comment_negative || '';
          const dateLabel = formatDate(review.review_published_at || review.stay_start_date);
          return (
            <article
              class="review-card"
              data-platform={review.platform}
              data-tags={review.tags.join(',')}
              data-duplicate={review.is_duplicate ? 'true' : 'false'}
              data-score={review.overall_score ?? 0}
              data-search={`${review.guest_name ?? ''} ${mainText} ${negativeText}`.toLowerCase()}
            >
              <header class="review-head">
                <div>
                  <div class="badges">
                    <span class={`badge badge-${review.platform}`}>{review.platform}</span>
                    {review.is_platform_translated && (
                      <span class="badge muted">texto traducido por plataforma</span>
                    )}
                    {review.is_duplicate && <span class="badge warning">duplicada</span>}
                  </div>

                  <h3>{review.guest_name ?? 'Huésped sin nombre'}</h3>
                  <p class="meta">
                    {dateLabel}
                    {review.nights ? ` · ${review.nights} noches` : ''}
                    {review.stay_start_date && review.stay_end_date
                      ? ` · estadía ${formatDate(review.stay_start_date)} → ${formatDate(review.stay_end_date)}`
                      : ''}
                  </p>
                </div>

                <div class="score-box">
                  <strong>{review.overall_score ?? '-'}</strong>
                  <span>{review.currency_or_scale === '10_point' ? '/10' : '/5'}</span>
                </div>
              </header>

              <div class="review-body">
                {review.title && <p class="title">{review.title}</p>}
                {mainText && <p class="quote">“{mainText}”</p>}

                {negativeText && (
                  <div class="negative">
                    <span>A mejorar</span>
                    <p>{negativeText}</p>
                  </div>
                )}

                {review.comment_private && (
                  <details>
                    <summary>Nota privada</summary>
                    <p>{review.comment_private}</p>
                  </details>
                )}

                <div class="chips">
                  {review.tags.map((tag) => (
                    <span class="chip small">{tagLabels[tag] ?? tag}</span>
                  ))}
                </div>
              </div>
            </article>
          );
        })}
      </section>
    </main>

    <script is:inline>
      const $ = (id) => document.getElementById(id);
      const search = $('search');
      const platform = $('platform');
      const tag = $('tag');
      const score = $('score');
      const hideDuplicates = $('hideDuplicates');
      const cards = Array.from(document.querySelectorAll('.review-card'));
      const count = $('resultsCount');

      function applyFilters() {
        const q = search.value.trim().toLowerCase();
        const platformValue = platform.value;
        const tagValue = tag.value;
        const scoreValue = Number(score.value || 0);
        const hideDupValue = hideDuplicates.checked;

        let visible = 0;

        cards.forEach((card) => {
          const matchesSearch = !q || card.dataset.search.includes(q);
          const matchesPlatform = platformValue === 'all' || card.dataset.platform === platformValue;
          const tags = (card.dataset.tags || '').split(',').filter(Boolean);
          const matchesTag = tagValue === 'all' || tags.includes(tagValue);
          const matchesScore = Number(card.dataset.score || 0) >= scoreValue;
          const matchesDuplicate = !hideDupValue || card.dataset.duplicate !== 'true';

          const show = matchesSearch && matchesPlatform && matchesTag && matchesScore && matchesDuplicate;
          card.style.display = show ? '' : 'none';
          if (show) visible += 1;
        });

        count.textContent = `${visible} reseñas visibles`;
      }

      [search, platform, tag, score, hideDuplicates].forEach((el) => {
        el.addEventListener('input', applyFilters);
        el.addEventListener('change', applyFilters);
      });

      applyFilters();
    </script>
  </body>
</html>

<style>
  :root {
    --bg: #f6f3ee;
    --card: #ffffff;
    --text: #211d1a;
    --muted: #746c65;
    --line: rgba(33, 29, 26, 0.1);
    --accent: #1f5f4a;
    --accent-soft: rgba(31, 95, 74, 0.09);
    --airbnb: #ff385c;
    --booking: #003b95;
    --warning: #8a5a00;
    --warning-bg: #fff6df;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: linear-gradient(180deg, #fbfaf8 0%, var(--bg) 100%);
    color: var(--text);
    font-family: Inter, system-ui, sans-serif;
  }

  .page {
    width: min(1280px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 72px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 20px;
    align-items: stretch;
    margin-bottom: 20px;
  }

  .hero-copy,
  .hero-stats,
  .panel,
  .toolbar,
  .review-card {
    background: rgba(255,255,255,0.75);
    backdrop-filter: blur(12px);
    border: 1px solid var(--line);
    border-radius: 24px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.04);
  }

  .hero-copy { padding: 28px; }
  .hero-copy h1 {
    margin: 8px 0 12px;
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }
  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.78rem;
  }
  .lead {
    max-width: 64ch;
    margin: 0;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .hero-stats {
    padding: 18px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .stat {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 16px;
  }
  .stat span, .stat small { display: block; color: var(--muted); }
  .stat strong { display:block; font-size: 2rem; margin: 6px 0; letter-spacing: -0.04em; }

  .summary {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  .panel { padding: 22px; }
  .panel h2 { margin-top: 0; margin-bottom: 14px; font-size: 1.1rem; }
  .panel ul { margin: 0; padding-left: 18px; color: var(--muted); line-height: 1.6; }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .chip {
    padding: 9px 12px;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid rgba(31,95,74,0.12);
    font-size: 0.92rem;
    line-height: 1;
  }
  .chip.small {
    padding: 7px 10px;
    font-size: 0.82rem;
  }

  .toolbar {
    padding: 16px;
    display: grid;
    grid-template-columns: 2fr repeat(3, minmax(140px, 1fr)) auto;
    gap: 12px;
    align-items: end;
    margin-bottom: 18px;
  }
  .field { display: grid; gap: 6px; }
  .field label, .check { font-size: 0.88rem; color: var(--muted); }
  input[type="search"], select {
    width: 100%;
    min-height: 48px;
    border-radius: 14px;
    border: 1px solid var(--line);
    padding: 0 14px;
    font: inherit;
    background: white;
    color: var(--text);
  }
  .check {
    display: flex;
    gap: 8px;
    align-items: center;
    padding-bottom: 12px;
  }

  .results-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    margin-bottom: 14px;
  }
  .results-head h2 {
    margin: 0 0 4px;
    font-size: 1.2rem;
    letter-spacing: -0.03em;
  }
  .results-head p {
    margin: 0;
    color: var(--muted);
  }

  .reviews {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .review-card { padding: 20px; }
  .review-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }
  .review-head h3 {
    margin: 8px 0 6px;
    font-size: 1.2rem;
    letter-spacing: -0.03em;
  }
  .meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid transparent;
  }
  .badge-airbnb { background: rgba(255,56,92,0.1); color: var(--airbnb); }
  .badge-booking { background: rgba(0,59,149,0.1); color: var(--booking); }
  .badge.muted { background: #f1ede8; color: #71665d; border-color: var(--line); }
  .badge.warning { background: var(--warning-bg); color: var(--warning); border-color: rgba(138,90,0,0.12); }

  .score-box {
    min-width: 76px;
    border-radius: 18px;
    padding: 12px;
    background: #faf7f3;
    border: 1px solid var(--line);
    text-align: center;
  }
  .score-box strong {
    display:block;
    font-size: 1.7rem;
    line-height: 1;
    letter-spacing: -0.05em;
  }
  .score-box span {
    color: var(--muted);
    font-size: 0.86rem;
  }

  .title {
    margin: 0 0 10px;
    font-weight: 700;
  }
  .quote {
    margin: 0 0 14px;
    line-height: 1.7;
    color: #302a26;
  }
  .negative {
    margin: 0 0 14px;
    padding: 14px;
    border-radius: 16px;
    background: #fcf7ef;
    border: 1px solid rgba(125,93,40,0.1);
  }
  .negative span {
    display:block;
    margin-bottom: 6px;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8a6332;
    font-weight: 700;
  }
  .negative p { margin: 0; line-height: 1.6; }
  details summary {
    cursor: pointer;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 8px;
  }
  details p { margin-top: 0; color: var(--muted); line-height: 1.6; }

  @media (max-width: 1080px) {
    .hero, .summary, .reviews, .toolbar {
      grid-template-columns: 1fr;
    }
    .toolbar {
      align-items: stretch;
    }
    .check {
      padding-bottom: 0;
      min-height: 48px;
    }
  }

  @media (max-width: 640px) {
    .page {
      width: min(100% - 20px, 1280px);
      padding-top: 16px;
    }
    .hero-copy, .panel, .review-card, .toolbar {
      border-radius: 20px;
    }
    .hero-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
