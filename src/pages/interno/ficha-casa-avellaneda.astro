---
import ficha from '../../data/ficha-casa-avellaneda.json';

const totalServicios = ficha.servicios_por_categoria.reduce((acc, cat) => acc + cat.items.length, 0);
const totalPenalizaciones = ficha.penalizaciones.length;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{ficha.nombre} | Ficha interna</title>
    <style>
      :root{
        --bg:#f5f1ea;
        --card:#fffdf9;
        --ink:#1f1a17;
        --muted:#6f675f;
        --line:#e5ddd3;
        --accent:#8f5e3b;
        --accent-2:#d8b08c;
        --ok:#325c43;
        --warn:#7a3d2b;
        --shadow:0 12px 40px rgba(30,22,16,.08);
        --radius:24px;
      }
      *{box-sizing:border-box}
      html{scroll-behavior:smooth}
      body{
        margin:0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color:var(--ink);
        background:
          radial-gradient(circle at top left, rgba(216,176,140,.25), transparent 32%),
          linear-gradient(180deg, #f8f4ee 0%, var(--bg) 100%);
      }
      .wrap{max-width:1200px;margin:0 auto;padding:28px 18px 80px}
      .hero{
        background:linear-gradient(135deg, rgba(255,255,255,.92), rgba(255,248,241,.84));
        border:1px solid rgba(143,94,59,.12);
        border-radius:32px;
        padding:28px;
        box-shadow:var(--shadow);
        backdrop-filter: blur(8px);
      }
      .eyebrow{
        display:inline-flex;align-items:center;gap:8px;
        font-size:12px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;
        color:var(--accent);
        background:rgba(143,94,59,.08);
        padding:10px 12px;border-radius:999px
      }
      h1{font-size:clamp(2rem,5vw,4rem);line-height:.95;margin:16px 0 12px}
      .lead{max-width:860px;color:var(--muted);font-size:1.04rem;line-height:1.7}
      .meta{
        margin-top:22px;
        display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px
      }
      .metaCard,.card{
        background:var(--card);border:1px solid var(--line);border-radius:var(--radius);
        box-shadow:var(--shadow);
      }
      .metaCard{padding:18px}
      .metaCard b{display:block;font-size:1.2rem;margin-top:6px}
      .metaCard span{font-size:.86rem;color:var(--muted)}
      .grid{
        display:grid;grid-template-columns:320px minmax(0,1fr);gap:24px;margin-top:26px
      }
      .sidebar{
        position:sticky;top:18px;align-self:start;padding:18px
      }
      .sidebar h3{margin:4px 0 14px;font-size:1rem}
      .sidebar a{
        display:flex;justify-content:space-between;gap:12px;
        color:var(--ink);text-decoration:none;padding:12px 14px;border-radius:16px;
        border:1px solid transparent;
      }
      .sidebar a:hover{background:#fff;border-color:var(--line)}
      .sidebar small{color:var(--muted)}
      .content{display:flex;flex-direction:column;gap:22px}
      section.card{padding:24px}
      h2{font-size:1.45rem;margin:0 0 14px}
      h3{font-size:1.02rem;margin:0 0 10px}
      p, li{line-height:1.65}
      .muted{color:var(--muted)}
      .chips{display:flex;flex-wrap:wrap;gap:10px}
      .chip{
        display:inline-flex;align-items:center;gap:8px;
        padding:10px 12px;border-radius:999px;
        background:#fff;border:1px solid var(--line);font-size:.92rem
      }
      .catGrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}
      .subcard{
        border:1px solid var(--line);border-radius:22px;padding:18px;background:#fff;
      }
      .subcard ul{padding-left:18px;margin:10px 0 0}
      .subcard li+li{margin-top:8px}
      .kicker{font-size:.82rem;color:var(--accent);font-weight:700;text-transform:uppercase;letter-spacing:.08em}
      .penaltyTable{display:grid;gap:10px}
      .row{
        display:grid;grid-template-columns:minmax(0,1fr) 150px 170px;gap:12px;
        padding:14px 16px;border:1px solid var(--line);border-radius:18px;background:#fff
      }
      .row b{display:block}
      .alert{
        border-radius:20px;padding:16px 18px;
        background:#fff7f2;border:1px solid rgba(122,61,43,.16);color:var(--warn)
      }
      .okbox{
        border-radius:20px;padding:16px 18px;
        background:#f6fbf7;border:1px solid rgba(50,92,67,.16);color:var(--ok)
      }
      .source{
        background:#faf7f2;border:1px dashed var(--line);border-radius:18px;padding:16px
      }
      code{background:#f2ece4;padding:2px 6px;border-radius:8px}
      @media (max-width: 980px){
        .meta,.grid,.catGrid,.row{grid-template-columns:1fr}
        .sidebar{position:relative;top:auto}
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="hero">
        <div class="eyebrow">Ficha interna normalizada</div>
        <h1>{ficha.nombre}</h1>
        <p class="lead">{ficha.subtitulo}. Esta página consolida y limpia la información publicada en plataforma para que puedas revisarla como una ficha operativa real, no como un listado crudo.</p>

        <div class="meta">
          <div class="metaCard">
            <span>Dirección</span>
            <b>{ficha.direccion}</b>
          </div>
          <div class="metaCard">
            <span>Capacidad normalizada</span>
            <b>{ficha.capacidad_publicada.huespedes} huéspedes</b>
          </div>
          <div class="metaCard">
            <span>Servicios estructurados</span>
            <b>{totalServicios}</b>
          </div>
          <div class="metaCard">
            <span>Penalizaciones</span>
            <b>{totalPenalizaciones}</b>
          </div>
        </div>
      </header>

      <div class="grid">
        <aside class="sidebar card">
          <h3>Navegación</h3>
          <a href="#resumen"><span>Resumen operativo</span><small>base</small></a>
          <a href="#servicios"><span>Servicios por categoría</span><small>{totalServicios}</small></a>
          <a href="#normas"><span>Normas normalizadas</span><small>9 bloques</small></a>
          <a href="#penalizaciones"><span>Penalizaciones</span><small>{totalPenalizaciones}</small></a>
          <a href="#dudosos"><span>Datos dudosos</span><small>trazabilidad</small></a>
          <a href="#fuentes"><span>Fuentes</span><small>origen</small></a>
        </aside>

        <main class="content">
          <section id="resumen" class="card">
            <div class="kicker">Resumen operativo</div>
            <h2>Datos clave ya normalizados</h2>
            <div class="chips">
              <div class="chip">Check-in <b>{ficha.checkin_checkout.check_in}</b></div>
              <div class="chip">Check-out <b>{ficha.checkin_checkout.check_out}</b></div>
              <div class="chip">Mascotas <b>{ficha.mascotas.permitidas ? "sí, con autorización" : "no"}</b></div>
              <div class="chip">Invitados no registrados <b>no permitidos</b></div>
              <div class="chip">Fumar en interior <b>prohibido</b></div>
              <div class="chip">Eventos <b>no recomendados / penalizables</b></div>
            </div>
            <div style="height:16px"></div>
            <div class="okbox">
              <b>Criterio aplicado</b>
              <div>{ficha.capacidad_publicada.observacion}</div>
              <div>{ficha.checkin_checkout.observacion}</div>
            </div>
          </section>

          <section id="servicios" class="card">
            <div class="kicker">Servicios</div>
            <h2>Todos los servicios ordenados por categoría</h2>
            <p class="muted">Acá no hay resumen recortado: está la ficha completa, reagrupada para que sea útil en web, operación o ventas.</p>
            <div class="catGrid">
              {ficha.servicios_por_categoria.map((grupo) => (
                <article class="subcard">
                  <h3>{grupo.categoria}</h3>
                  <ul>
                    {grupo.items.map((item) => (
                      <li><b>{item.nombre}.</b> {item.detalle}</li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </section>

          <section id="normas" class="card">
            <div class="kicker">Normas</div>
            <h2>Reglas de la casa normalizadas</h2>
            <div class="catGrid">
              {ficha.normas_normalizadas.map((bloque) => (
                <article class="subcard">
                  <h3>{bloque.titulo}</h3>
                  <ul>
                    {bloque.reglas.map((regla) => <li>{regla}</li>)}
                  </ul>
                </article>
              ))}
            </div>
          </section>

          <section id="penalizaciones" class="card">
            <div class="kicker">Penalizaciones</div>
            <h2>Tabla consolidada de cargos y sanciones</h2>
            <div class="penaltyTable">
              {ficha.penalizaciones.map((p) => (
                <div class="row">
                  <div><b>{p.motivo}</b></div>
                  <div><span class="muted">Cargo</span><br />{p.cargo_usd} USD</div>
                  <div><span class="muted">Aplicación</span><br />{p.tipo}</div>
                </div>
              ))}
            </div>
          </section>

          <section id="dudosos" class="card">
            <div class="kicker">Control de calidad</div>
            <h2>Datos publicados dudosos o mal cargados</h2>
            <div class="alert">
              Esta sección existe a propósito: no borra información, pero evita que errores de plataforma contaminen la ficha final.
            </div>
            <div style="height:16px"></div>
            <div class="catGrid">
              {ficha.servicios_dudosos_publicados.map((d) => (
                <article class="subcard">
                  <h3>{d.nombre}</h3>
                  <p><b>Motivo:</b> {d.motivo}</p>
                  <p class="muted"><b>Texto original:</b> {d.texto_original}</p>
                </article>
              ))}
            </div>
          </section>

          <section id="fuentes" class="card">
            <div class="kicker">Fuentes</div>
            <h2>Trazabilidad</h2>
            <div class="source">
              <p><b>Archivo de servicios:</b> <code>{ficha.fuentes.servicios}</code></p>
              <p><b>Archivo de normas:</b> <code>{ficha.fuentes.normas}</code></p>
              <p class="muted">La ficha fue pensada para que puedas usarla como base de una sección interna Astro, y a la vez dejar visible qué se normalizó y qué se descartó como error.</p>
            </div>
          </section>
        </main>
      </div>
    </div>
  </body>
</html>
