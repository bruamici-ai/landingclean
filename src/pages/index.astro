---
import BaseLayout from '../layouts/BaseLayout.astro';
import MobileGalleryOverlay from "../components/MobileGalleryOverlay.astro";

const phone = '5492616931948';
const wa = `https://wa.me/${phone}?text=Hola%20Bruno,%20quiero%20consultar%20por%20La%20Casa%20Frente%20al%20Parque`;

const heroImage = 'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775873954/BRU_1444_dywtrx.jpg';

const gallery = [
  'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775873954/BRU_1444_dywtrx.jpg',
  'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775873954/_BRU1843_nawict.jpg',
  'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775873952/_BRU1774_wyxxjb.jpg',
  'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775873945/_BRU1602_a7hpbb.jpg',
  'https://res.cloudinary.com/drne78uzo/image/upload/q_auto,f_auto/v1775873941/_BRU1510_kupufv.jpg',
];

const highlights = [
  {
    icon: '🌳',
    title: 'Ubicación privilegiada frente al parque',
    text: 'Frente al Parque General San Martín, en una zona muy buscada, tranquila y bien conectada con bares, restaurantes y paseos.'
  },
  {
    icon: '💦',
    title: 'Pileta, jacuzzi y patio privado',
    text: 'Uno de los diferenciales más fuertes de la casa, ideal para transformar una estadía en una experiencia más completa.'
  },
  {
    icon: '👨‍👩‍👧‍👦',
    title: 'Escala real para grupos y familias',
    text: 'Hasta 14 huéspedes, 4 dormitorios, 12 camas y espacios comunes amplios que permiten convivir cómodamente.'
  },
  {
    icon: '✨',
    title: 'Hospitalidad muy bien valorada',
    text: 'Las reseñas destacan atención cercana, respuestas rápidas y una experiencia cálida desde la llegada.'
  }
];

const useCases = [
  {
    title: 'Ideal para familias',
    text: 'Por su distribución, amplitud y patio, funciona muy bien para viajes con chicos o grupos familiares.'
  },
  {
    title: 'Excelente para grupos',
    text: 'Living, comedor, cocina y exterior permiten compartir mucho mejor que en un alojamiento estándar.'
  },
  {
    title: 'Muy buena para estadías largas',
    text: 'Wifi rápido, lavarropas, cocina equipada y una ubicación cómoda para vivir Mendoza con libertad.'
  }
];

const amenities = [
  ['Pileta privada', 'Disponible según temporada, dentro de un patio pensado para disfrutar el exterior.'],
  ['Jacuzzi privado', 'Disponible todo el año y muy valorado por quienes buscan una experiencia más confortable.'],
  ['Wifi 96 Mbps', 'Verificado, útil para videollamadas, trabajo remoto y streaming.'],
  ['Estacionamiento', 'Hasta 3 plazas dentro de la propiedad, más opciones en la calle.'],
  ['TV + home theater', 'Televisor HD de 55” con Netflix y sistema Sony con bluetooth.'],
  ['Cocina equipada', 'Heladera, horno, microondas, lavavajillas, cafetera, tostadora y vajilla.'],
  ['Parrilla y comedor exterior', 'Un punto muy fuerte para grupos, reuniones y noches de asado.'],
  ['Check-in autónomo', 'Caja de seguridad para llaves y llegada más flexible.'],
  ['Pet friendly', 'Se permiten mascotas, algo muy valioso para cierto perfil de huésped.'],
  ['Zona de trabajo', 'Útil para estadías largas o viajes que mezclan descanso y trabajo.'],
  ['Cuna incluida', 'Muy buena ventaja para familias.'],
  ['Entorno y vistas', 'Vista al parque, patio y un sector muy bien percibido de la ciudad.']
];

const reviews = [
  {
    text: 'Nuestra estadía fue simplemente perfecta. La ubicación es inmejorable, la casa es un sueño, impecable, muy cómoda y súper bien equipada.',
    author: 'Jose Eugenio · febrero 2026'
  },
  {
    text: 'Desde el minuto de la reserva Bruno estuvo atento a absolutamente todo. La casa es espectacular y muy cómoda. Si vuelvo a Mendoza, claramente volvería acá.',
    author: 'Ariel · marzo 2026'
  },
  {
    text: 'Muy buena ubicación, la casa súper amplia y bien equipada. Bruno respondió rápidamente y generó un ambiente muy acogedor.',
    author: 'Ignacio · marzo 2026'
  },
  {
    text: 'Todo estuvo fenomenal. La ubicación es perfecta, frente al parque, cerca de restaurantes y bares. La casa está súper bien equipada.',
    author: 'Juan · noviembre 2025'
  }
];
---

<BaseLayout
  title="La Casa Frente al Parque | Mendoza"
  description="Casa premium frente al Parque San Martín en Mendoza. Hasta 14 huéspedes, pileta, jacuzzi, patio, parrilla y ubicación privilegiada."
  image={heroImage}
  url="https://casafrentealparque.pages.dev/"
>
  <header class="topbar">
    <div class="container topbar-inner">
      <a href="#" class="brand">
        <div class="brand-mark">LP</div>
        <div class="brand-copy">
          <strong>La Casa Frente al Parque</strong>
          <span>Mendoza · Argentina</span>
        </div>
      </a>

      <nav class="nav">
        <a href="#experiencia">Experiencia</a>
        <a href="#galeria">Galería</a>
        <a href="#servicios">Servicios</a>
        <a href="#opiniones">Opiniones</a>
      </nav>

      <div class="top-right">
        <div class="score-pill">4,95 · 76 reseñas</div>
        <a class="top-cta" href={wa} target="_blank" rel="noreferrer">Consultar por WhatsApp</a>
      </div>
    </div>
  </header>

  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-main">
          <img src={heroImage} alt="La Casa Frente al Parque - foto principal" loading="eager" fetchpriority="high" />
          <div class="hero-overlay"></div>
          <div class="hero-copy">
            <div class="eyebrow">Top 10% · Favorito entre huéspedes · 4,95/5</div>
            <h1>Una casa con presencia, color y alma mendocina frente al parque.</h1>
            <p class="hero-sub">
              Amplia, cálida y pensada para grupos y familias que buscan una experiencia especial en Mendoza,
              con pileta, jacuzzi, parrilla y una de las ubicaciones más buscadas de la ciudad.
            </p>
            <div class="hero-actions">
              <a class="btn btn-primary" href={wa} target="_blank" rel="noreferrer">Consultar disponibilidad</a>
              <a class="btn btn-secondary" href="#galeria">Ver fotos</a>
            </div>
          </div>
        </div>

        <div class="hero-side">
          <div class="side-card">
            <img src={gallery[1]} alt="Dormitorio o ambiente premium" loading="lazy" />
            <div class="side-label">Descanso premium</div>
          </div>
          <div class="side-card">
            <img src={gallery[2]} alt="Exterior o patio" loading="lazy" />
            <div class="side-label">Exterior disfrutable</div>
          </div>
          <div class="side-card tall">
            <img src={gallery[3]} alt="Interior amplio" loading="lazy" />
            <div class="side-label">Interiores amplios</div>
          </div>
        </div>
      </div>

      <div class="stats">
        <div class="stat"><strong>14</strong><span>huéspedes</span></div>
        <div class="stat"><strong>4</strong><span>dormitorios</span></div>
        <div class="stat"><strong>12</strong><span>camas</span></div>
        <div class="stat"><strong>2,5</strong><span>baños</span></div>
        <div class="stat"><strong>96 Mbps</strong><span>wifi rápido</span></div>
      </div>
    </div>
  </section>

  <main>
    <section id="experiencia">
      <div class="container">
        <div class="section-head">
          <div>
            <h2>Una experiencia que se entiende apenas la ves</h2>
          </div>
          <p>
            Frente al Parque General San Martín, esta casa combina amplitud, calidez y una ubicación privilegiada para disfrutar Mendoza con comodidad.
          </p>
        </div>

        <div class="split">
          <div class="panel">
            <div class="kicker">La experiencia</div>
            <p class="lead">
              Esta casa transmite una sensación difícil de lograr en una publicación: espacios reales, carácter propio y un exterior que suma mucho valor a la estadía.
            </p>
            <p class="lead">
              Es ideal para quienes buscan reunirse, descansar y vivir Mendoza con más comodidad, sin resignar ubicación, amplitud ni personalidad.
            </p>
            <div class="badges">
              <span class="badge">Frente al parque</span>
              <span class="badge">Pileta privada</span>
              <span class="badge">Jacuzzi</span>
              <span class="badge">Parrilla</span>
              <span class="badge">Ideal para grupos</span>
            </div>
          </div>

          <div class="feature-list">
            {highlights.map((item) => (
              <article class="feature">
                <div class="feature-icon">{item.icon}</div>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="galeria">
      <div class="container">
        <div class="section-head">
          <div>
            <h2>Galería curada con las fotos reales</h2>
          </div>
          <p>
            Una selección de imágenes reales para mostrar los espacios más valorados por quienes se hospedan.
          </p>
        </div>

        <div class="gallery-grid">
          <a class="gallery-big js-lightbox" href={gallery[0]}>
            <img src={gallery[0]} alt="Foto principal de la casa" loading="lazy" />
          </a>

          <div class="gallery-small">
            <a class="js-lightbox" href={gallery[1]}><img src={gallery[1]} alt="Imagen 1" loading="lazy" /></a>
            <a class="js-lightbox" href={gallery[2]}><img src={gallery[2]} alt="Imagen 2" loading="lazy" /></a>
            <a class="js-lightbox" href={gallery[3]}><img src={gallery[3]} alt="Imagen 3" loading="lazy" /></a>
            <a class="js-lightbox" href={gallery[4]}><img src={gallery[4]} alt="Imagen 4" loading="lazy" /></a>
          </div>
        </div>

        <MobileGalleryOverlay />
      </div>
    </section>

    <section>
      <div class="container">
        <div class="section-head">
          <div>
            <h2>Ideal para este tipo de viaje</h2>
          </div>
          <p>
            Espacios pensados para familias, grupos y estadías cómodas en Mendoza.
          </p>
        </div>

        <div class="use-cases">
          {useCases.map((item) => (
            <article class="use-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="servicios">
      <div class="container">
        <div class="section-head">
          <div>
            <h2>Servicios que realmente suman valor</h2>
          </div>
          <p>
            Una selección clara de los servicios que más influyen en la decisión de reserva.
          </p>
        </div>

        <div class="amenities">
          {amenities.map(([title, text]) => (
            <article class="amenity">
              <strong>{title}</strong>
              <span>{text}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="opiniones">
      <div class="container">
        <div class="section-head">
          <div>
            <h2>Opiniones de huéspedes</h2>
          </div>
          <p>
            Reseñas reales que repiten los mismos puntos fuertes: ubicación, comodidad y atención.
          </p>
        </div>

        <div class="review-layout">
          <div class="review-score">
            <strong>4,95</strong>
            <p>
              Calificación promedio sobre 5<br />
              76 evaluaciones reales<br />
              Favorito entre huéspedes<br />
              Top 10% de los alojamientos mejor valorados
            </p>
          </div>

          <div class="review-grid">
            {reviews.map((review) => (
              <blockquote class="review">
                <p>“{review.text}”</p>
                <footer>{review.author}</footer>
              </blockquote>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <div class="cta-box">
          <h2>Consultá fechas y resolvé todo directo por WhatsApp.</h2>
          <p>
            Si buscás una casa con personalidad, espacios amplios y una ubicación premium en Mendoza,
            esta propiedad tiene argumentos muy fuertes para convencer.
          </p>
          <div class="cta-actions">
            <a class="btn btn-light" href={wa} target="_blank" rel="noreferrer">Escribir ahora</a>
            <a class="btn btn-ghost" href="#galeria">Seguir viendo fotos</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      La Casa Frente al Parque · Mendoza, Argentina
    </div>
  </footer>

  <div class="lightbox" id="lightbox">
    <div class="lightbox-inner">
      <button class="lightbox-close" id="lightboxClose" aria-label="Cerrar">×</button>
      <img id="lightboxImg" src="" alt="Imagen ampliada" />
    </div>
  </div>

  <div class="mobile-wa">
    <a href={wa} target="_blank" rel="noreferrer">Consultar por WhatsApp</a>
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg');
    const lightboxClose = document.getElementById('lightboxClose');
    const triggers = document.querySelectorAll('.js-lightbox');

    triggers.forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const href = el.getAttribute('href');
        if (!href || !lightbox || !lightboxImg) return;
        lightboxImg.src = href;
        lightbox.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });

    if (lightboxClose) {
      lightboxClose.addEventListener('click', () => {
        if (!lightbox || !lightboxImg) return;
        lightbox.classList.remove('open');
        lightboxImg.src = '';
        document.body.style.overflow = '';
      });
    }

    if (lightbox) {
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) {
          lightbox.classList.remove('open');
          if (lightboxImg) lightboxImg.src = '';
          document.body.style.overflow = '';
        }
      });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox?.classList.contains('open')) {
        lightbox.classList.remove('open');
        if (lightboxImg) lightboxImg.src = '';
        document.body.style.overflow = '';
      }
    });
  </script>
</BaseLayout>
